<?xml version="1.0" encoding="UTF-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:InventoryApp.ViewModels"
             x:Class="InventoryApp.Views.InventoryDetailPage"
             x:DataType="vm:InventoryDetailViewModel"
             Title="{Binding Title}">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="16">

            <Frame BackgroundColor="{StaticResource ErrorRed}"
                   IsVisible="{Binding HasError}"
                   Padding="10"
                   CornerRadius="6">
                <Label Text="{Binding ErrorMessage}" TextColor="White" />
            </Frame>

            <Frame BackgroundColor="{StaticResource SuccessGreen}"
                   IsVisible="{Binding SaveSucceeded}"
                   Padding="10"
                   CornerRadius="6">
                <Label Text="Quantity updated successfully." TextColor="White" />
            </Frame>

            <ActivityIndicator IsRunning="{Binding IsBusy}"
                                IsVisible="{Binding IsBusy}"
                                HorizontalOptions="Center" />

            <Label Text="{Binding ItemName}" FontSize="22" FontAttributes="Bold" />

            <Label Text="{Binding LastUpdated, StringFormat='Last updated: {0:dd/MM/yyyy HH:mm}'}"
                   FontSize="13" TextColor="Gray" />

            <Label Text="Current Quantity" FontAttributes="Bold" Margin="0,12,0,0" />

            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                <Entry Grid.Column="0"
                       Text="{Binding CurrentQuantity}"
                       Keyboard="Numeric" />
                <Stepper Grid.Column="1"
                         Value="{Binding CurrentQuantity}"
                         Minimum="0"
                         Maximum="100000"
                         Increment="1" />
            </Grid>

            <Button Text="Save"
                    Command="{Binding SaveCommand}"
                    IsEnabled="{Binding IsBusy, Converter={StaticResource InvertedBoolConverter}}"
                    Margin="0,20,0,0" />

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>

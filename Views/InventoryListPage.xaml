<?xml version="1.0" encoding="UTF-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:InventoryApp.ViewModels"
             xmlns:models="clr-namespace:InventoryApp.Models"
             x:Class="InventoryApp.Views.InventoryListPage"
             x:DataType="vm:InventoryListViewModel"
             Title="{Binding Title}">

    <Grid RowDefinitions="Auto,*" Padding="12">

        <Frame Grid.Row="0"
               BackgroundColor="{StaticResource ErrorRed}"
               IsVisible="{Binding HasError}"
               Padding="10"
               Margin="0,0,0,8"
               CornerRadius="6">
            <Label Text="{Binding ErrorMessage}" TextColor="White" />
        </Frame>

        <RefreshView Grid.Row="1"
                     IsRefreshing="{Binding IsBusy}"
                     Command="{Binding LoadItemsCommand}">

            <CollectionView ItemsSource="{Binding Items}"
                             SelectionMode="Single"
                             x:Name="ItemsCollectionView">

                <CollectionView.EmptyView>
                    <Label Text="No inventory items found."
                           HorizontalOptions="Center"
                           VerticalOptions="Center"
                           TextColor="Gray" />
                </CollectionView.EmptyView>

                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="models:InventoryItem">
                        <Grid Padding="12,10" ColumnDefinitions="*,Auto">

                            <Grid.GestureRecognizers>
                                <TapGestureRecognizer
                                    Command="{Binding Source={RelativeSource AncestorType={x:Type vm:InventoryListViewModel}}, Path=GoToDetailCommand}"
                                    CommandParameter="{Binding .}" />
                            </Grid.GestureRecognizers>

                            <VerticalStackLayout Grid.Column="0" Spacing="2">
                                <Label Text="{Binding ItemName}" FontAttributes="Bold" FontSize="16" />
                                <Label Text="{Binding LastUpdated, StringFormat='Last updated: {0:dd/MM/yyyy HH:mm}'}"
                                       FontSize="12" TextColor="Gray" />
                            </VerticalStackLayout>

                            <Label Grid.Column="1"
                                   Text="{Binding CurrentQuantity}"
                                   FontSize="20"
                                   FontAttributes="Bold"
                                   VerticalOptions="Center" />
                        </Grid>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </RefreshView>
    </Grid>

</ContentPage>
